class Solution {
    public int minimumSwaps(int[] nums) {
        int zerocount=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]==0){
                zerocount++;
            }
        }
        int limit = nums.length-zerocount;
        int swaps =0;
        for(int i=0;i<limit;i++){
            if(nums[i]==0){
                swaps++;
            }            
        }
        return swaps;        
    }
}
